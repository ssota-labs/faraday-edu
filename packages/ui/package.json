{
  "name": "@faraday-academy/ui",
  "version": "0.2.0",
  "type": "module",
  "description": "Faraday shared design system — shadcn/Base UI primitives (.cn-* + CSS style layer). Lessons consume via @faraday-academy/kit re-exports; the platform app imports this package directly with platform.css.",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    "./components/ui/*": "./src/components/ui/*.tsx",
    "./lib/utils": "./src/lib/utils.ts",
    "./lesson.css": "./src/lesson.css",
    "./platform.css": "./src/platform.css",
    "./styles/*": "./src/styles/*",
    "./package.json": "./package.json",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "files": [
    "src",
    "LICENSE.md"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "prepack": "cp ../../LICENSE.md ./LICENSE.md 2>/dev/null || true"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssota-labs/faraday-academy.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/ssota-labs/faraday-academy#readme",
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.6.0",
    "sonner": "^2.0.7",
    "react-resizable-panels": "^4.11.2",
    "@shadcn/react": "^0.2.1"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.0"
  },
  "license": "SEE LICENSE IN LICENSE.md"
}
