# Tutor AI — the durable chat agent needs an AI Gateway key for model calls.
#
# LOCAL (BYO key): copy this file to `.env.local` and paste your Vercel AI Gateway
# key. Get one at https://vercel.com/dashboard -> AI Gateway -> API keys.
#   cp env.example .env.local
AI_GATEWAY_API_KEY=

# On Vercel, don't set this — deployments authenticate to AI Gateway via OIDC
# automatically. `.env.local` is git-ignored; never commit a real key.
