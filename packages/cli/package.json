{
  "name": "@faraday-academy/cli",
  "version": "0.1.0",
  "description": "Faraday Academy — a shadcn-based scaffolder for AI-authored interactive lessons, with installable module packs (faraday pack add).",
  "type": "module",
  "bin": {
    "faraday": "./bin/faraday.mjs"
  },
  "files": ["bin", "src", "templates", "packs", "LICENSE.md"],
  "scripts": {
    "build": "node scripts/bundle-packs.mjs",
    "test": "node --test src/*.test.mjs",
    "prepack": "node scripts/bundle-packs.mjs && (cp ../../LICENSE.md ./LICENSE.md 2>/dev/null || true)"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssota-labs/faraday-academy.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ssota-labs/faraday-academy#readme",
  "bugs": {
    "url": "https://github.com/ssota-labs/faraday-academy/issues"
  },
  "license": "SEE LICENSE IN LICENSE.md"
}
