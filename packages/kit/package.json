{
  "name": "@faraday-academy/kit",
  "version": "0.3.0",
  "type": "module",
  "description": "The minimal Faraday lesson kit: portable blocks and runtime helpers for agent-built courseware.",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    "./blocks": "./blocks/index.ts",
    "./runtime": "./runtime/index.ts",
    "./styles.css": "./faraday.css",
    "./faraday.css": "./faraday.css",
    "./package.json": "./package.json"
  },
  "files": [
    "blocks",
    "runtime",
    "faraday.css",
    "vite-env.d.ts",
    "LICENSE.md"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "prepack": "cp ../../LICENSE.md ./LICENSE.md 2>/dev/null || true"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssota-labs/faraday-academy.git",
    "directory": "packages/kit"
  },
  "homepage": "https://github.com/ssota-labs/faraday-academy#readme",
  "peerDependencies": {
    "@faraday-academy/ui": "0.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "katex": "^0.16.11",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@faraday-academy/ui": "workspace:*",
    "@types/katex": "^0.16.7",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.0.0",
    "typescript": "~5.9.0"
  },
  "license": "SEE LICENSE IN LICENSE.md"
}
