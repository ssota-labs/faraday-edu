{
  "name": "@faraday-academy/platform-adapter-supabase",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Supabase adapter for Faraday platform — migrations live in /supabase; seed + client helpers here.",
  "exports": {
    ".": "./src/index.ts",
    "./constants": "./src/constants.ts",
    "./migrations": "./migrations/001_init.sql"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "db:seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@faraday-academy/platform-contracts": "workspace:*",
    "@faraday-academy/platform-core": "workspace:*",
    "@supabase/supabase-js": "^2.108.1",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^24",
    "tsx": "^4.20.3",
    "typescript": "~5.9.0"
  }
}
