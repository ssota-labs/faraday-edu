{
  "name": "@faraday-academy/tutor",
  "version": "0.2.0",
  "description": "Faraday Academy tutor addon — the durable <Tutor> chat widget (client), docked beside the lesson with Markdown/math rendering. Pairs with the author-editable Nitro + Workflow server that `faraday new --tutor` drops into the lesson.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE.md",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./index.ts",
    "./styles.css": "./styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "chat",
    "dock.tsx",
    "index.ts",
    "resizable.tsx",
    "styles.css",
    "tutor.tsx",
    "vite-env.d.ts",
    "LICENSE.md"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "prepack": "cp ../../LICENSE.md ./LICENSE.md 2>/dev/null || true"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssota-labs/faraday-academy.git",
    "directory": "packages/tutor"
  },
  "homepage": "https://github.com/ssota-labs/faraday-academy#readme",
  "dependencies": {
    "@ai-sdk/react": "^4.0.12",
    "@ai-sdk/workflow": "^1.0.11",
    "@base-ui/react": "^1.5.0",
    "@phosphor-icons/react": "^2.1.10",
    "@shadcn/react": "^0.2.1",
    "@streamdown/math": "^1.0.2",
    "ai": "^7.0.11",
    "class-variance-authority": "^0.7.1",
    "react-resizable-panels": "^4.12.1",
    "streamdown": "^2.5.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@faraday-academy/kit": "0.2.0",
    "@faraday-academy/ui": "0.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "~5.9.0",
    "vite": "^7.0.0",
    "@faraday-academy/kit": "workspace:*",
    "@faraday-academy/ui": "workspace:*"
  }
}
