{
  "name": "faraday",
  "private": true,
  "description": "Faraday monorepo — the @faraday-academy/cli scaffolder, the runtime + addon packages lessons pin, and the platform catalog.",
  "scripts": {
    "test": "pnpm --filter @faraday-academy/cli test && node --test scripts/setup-env-local.test.mjs",
    "test:cli": "pnpm --filter @faraday-academy/cli test",
    "typecheck": "pnpm --filter @faraday-academy/ui typecheck && pnpm --filter @faraday-academy/kit typecheck && pnpm --filter @faraday-academy/lms typecheck && pnpm --filter @faraday-academy/labs typecheck && pnpm --filter @faraday-academy/platform typecheck",
    "harness:docs": "node scripts/harness/check-docs.mjs",
    "harness:boundaries": "node scripts/harness/check-boundaries.mjs",
    "verify:quick": "pnpm harness:docs && pnpm harness:boundaries && pnpm typecheck && pnpm test",
    "verify:final": "pnpm verify:quick && pnpm e2e:ci",
    "e2e": "bash scripts/e2e-report.sh",
    "e2e:ci": "bash scripts/e2e-report.sh --no-report",
    "e2e:prepare": "pnpm exec supabase start && pnpm db:migrate && pnpm db:seed",
    "cloud:prepare": "bash scripts/cloud-bootstrap.sh",
    "sync:env": "bash scripts/sync-supabase-env.sh",
    "db:migrate": "pnpm exec supabase migration up --local",
    "db:migrate:down": "pnpm exec supabase migration down --local",
    "db:migration:new": "pnpm exec supabase migration new",
    "db:migration:list": "pnpm exec supabase migration list --local",
    "db:reset": "pnpm exec supabase db reset --local",
    "db:seed": "pnpm --filter @faraday-academy/platform-e2e seed",
    "publish:packages": "node scripts/publish-packages.mjs",
    "publish:packages:dry": "node scripts/publish-packages.mjs --dry-run",
    "sync:skills": "node scripts/sync-skills.mjs",
    "sync:skills:check": "node scripts/sync-skills.mjs --check",
    "setup:env": "node scripts/setup-env-local.mjs",
    "stage1:cold-e2e": "node scripts/stage1-cold-e2e.mjs"
  },
  "devDependencies": {
    "supabase": "^2.105.0"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "pnpm@11.5.2"
}
